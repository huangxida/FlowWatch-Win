<Window x:Class="FlowWatch.Views.AppTrafficWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:FlowWatch.ViewModels"
        Title="{DynamicResource AppTraffic.WindowTitle}"
        Width="820" Height="640"
        MinWidth="680" MinHeight="480"
        ResizeMode="CanResizeWithGrip"
        WindowStartupLocation="CenterScreen"
        Style="{StaticResource SettingsWindowStyle}"
        ShowInTaskbar="True">
    <Window.DataContext>
        <vm:AppTrafficViewModel/>
    </Window.DataContext>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource CardBorderBrush}" BorderThickness="0,0,0,1"
                Padding="24,20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Border Grid.Column="1" Background="{StaticResource SurfaceBrush}"
                        BorderBrush="{StaticResource CardBorderBrush}" BorderThickness="1"
                        CornerRadius="8" Padding="3" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <RadioButton Content="{DynamicResource AppTraffic.Realtime}" GroupName="AppRange"
                                     IsChecked="{Binding IsRealtimeSelected, Mode=OneWay}"
                                     Command="{Binding RealtimeCommand}"
                                     Style="{StaticResource RangeTabStyle}"/>
                        <RadioButton Content="{DynamicResource AppTraffic.Day}" GroupName="AppRange"
                                     IsChecked="{Binding IsDaySelected, Mode=OneWay}"
                                     Command="{Binding DayCommand}"
                                     Style="{StaticResource RangeTabStyle}"/>
                        <RadioButton Content="{DynamicResource AppTraffic.Week}" GroupName="AppRange"
                                     IsChecked="{Binding IsWeekSelected, Mode=OneWay}"
                                     Command="{Binding WeekCommand}"
                                     Style="{StaticResource RangeTabStyle}"/>
                        <RadioButton Content="{DynamicResource AppTraffic.Month}" GroupName="AppRange"
                                     IsChecked="{Binding IsMonthSelected, Mode=OneWay}"
                                     Command="{Binding MonthCommand}"
                                     Style="{StaticResource RangeTabStyle}"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <Border Grid.Row="1" Background="{StaticResource SurfaceAltBrush}"
                BorderBrush="{StaticResource CardBorderBrush}" BorderThickness="0,0,0,1"
                Padding="24,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="{DynamicResource AppTraffic.Download}" Style="{StaticResource MetricTitleStyle}"/>
                    <TextBlock Text="{Binding TotalDownloadFormatted}" Style="{StaticResource ValueStyle}"
                               Foreground="{StaticResource AccentBrush}" Margin="0,4,0,0"/>
                </StackPanel>
                <StackPanel Grid.Column="1">
                    <TextBlock Text="{DynamicResource AppTraffic.Upload}" Style="{StaticResource MetricTitleStyle}"/>
                    <TextBlock Text="{Binding TotalUploadFormatted}" Style="{StaticResource ValueStyle}"
                               Foreground="{StaticResource OrangeBrush}" Margin="0,4,0,0"/>
                </StackPanel>
                <StackPanel Grid.Column="2">
                    <TextBlock Text="{DynamicResource AppTraffic.TotalTraffic}" Style="{StaticResource MetricTitleStyle}"/>
                    <TextBlock Text="{Binding SummaryTotalFormatted}" Style="{StaticResource ValueStyle}"
                               Foreground="{StaticResource PurpleBrush}" Margin="0,4,0,0"/>
                </StackPanel>
                <StackPanel Grid.Column="3">
                    <TextBlock Text="{DynamicResource AppTraffic.TopApp}" Style="{StaticResource MetricTitleStyle}"/>
                    <TextBlock Text="{Binding TopAppName}" Style="{StaticResource ValueStyle}"
                               Margin="0,4,0,0"/>
                </StackPanel>
                <StackPanel Grid.Column="4">
                    <TextBlock Text="{DynamicResource AppTraffic.Apps}" Style="{StaticResource MetricTitleStyle}"/>
                    <TextBlock Text="{Binding AppCountLabel}" Style="{StaticResource ValueStyle}"
                               Foreground="{StaticResource GreenBrush}" Margin="0,4,0,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="2" Margin="24,20,24,24">
            <Border Style="{StaticResource SoftPanelStyle}" Visibility="{Binding EmptyVisibility}">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock Text="{DynamicResource AppTraffic.NoData}" FontSize="18" FontWeight="SemiBold"
                               Foreground="{StaticResource TextBrush}" HorizontalAlignment="Center"/>
                    <TextBlock Text="{DynamicResource AppTraffic.NoDataHint}" Style="{StaticResource HintStyle}"
                               TextAlignment="Center" Margin="0,6,0,0"/>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource ModernCardStyle}" Visibility="{Binding RecordsVisibility}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="28"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="1" Text="{DynamicResource AppTraffic.AppColumn}" Style="{StaticResource TableHeaderStyle}"/>
                        <TextBlock Grid.Column="2" Text="{DynamicResource AppTraffic.Download}" Style="{StaticResource TableHeaderStyle}" TextAlignment="Right"/>
                        <TextBlock Grid.Column="3" Text="{DynamicResource AppTraffic.Upload}" Style="{StaticResource TableHeaderStyle}" TextAlignment="Right"/>
                        <TextBlock Grid.Column="4" Text="{DynamicResource AppTraffic.TotalTraffic}" Style="{StaticResource TableHeaderStyle}" TextAlignment="Right"/>
                        <TextBlock Grid.Column="5" Text="{DynamicResource AppTraffic.Share}" Style="{StaticResource TableHeaderStyle}" TextAlignment="Right"/>
                    </Grid>

                    <ScrollViewer Grid.Row="1" Style="{StaticResource ModernScrollViewerStyle}" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding AppRecords}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource TableRowStyle}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="100"/>
                                                <ColumnDefinition Width="100"/>
                                                <ColumnDefinition Width="100"/>
                                                <ColumnDefinition Width="80"/>
                                            </Grid.ColumnDefinitions>
                                            <Grid Grid.Column="0" VerticalAlignment="Center">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="34"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <Grid Width="24" Height="24" Grid.Column="0" HorizontalAlignment="Left" VerticalAlignment="Center">
                                                    <Border Width="24" Height="24" CornerRadius="6"
                                                            Background="{StaticResource AccentSoftBrush}"
                                                            BorderBrush="#FFDCE6F3" BorderThickness="1"
                                                            Visibility="{Binding IconFallbackVisibility}">
                                                        <TextBlock Text="{Binding IconFallback}"
                                                                   Foreground="{StaticResource AccentBrush}"
                                                                   FontWeight="SemiBold" FontSize="11"
                                                                   HorizontalAlignment="Center"
                                                                   VerticalAlignment="Center"/>
                                                    </Border>
                                                    <Image Source="{Binding Icon}" Width="24" Height="24"
                                                           Visibility="{Binding IconVisibility}"
                                                           RenderOptions.BitmapScalingMode="HighQuality"/>
                                                </Grid>
                                                <Grid Grid.Column="1" MinWidth="0">
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                    </Grid.RowDefinitions>
                                                    <TextBlock Text="{Binding ProcessName}" Style="{StaticResource TableCellTextStyle}"
                                                               FontWeight="SemiBold"/>
                                                    <Grid Grid.Row="1" Height="6" Margin="0,5,16,0">
                                                        <Border Background="#FFE8EEF6" CornerRadius="3"/>
                                                        <Border Background="{StaticResource AccentBrush}" CornerRadius="3"
                                                                HorizontalAlignment="Left">
                                                            <Border.Width>
                                                                <MultiBinding Converter="{StaticResource RatioToWidthConverter}">
                                                                    <Binding Path="TotalRatio"/>
                                                                    <Binding Path="ActualWidth" RelativeSource="{RelativeSource AncestorType=Grid}"/>
                                                                </MultiBinding>
                                                            </Border.Width>
                                                        </Border>
                                                    </Grid>
                                                </Grid>
                                            </Grid>
                                            <TextBlock Grid.Column="1" Text="{Binding DownloadFormatted}"
                                                       Style="{StaticResource MonoCellTextStyle}"
                                                       Foreground="{StaticResource AccentBrush}"/>
                                            <TextBlock Grid.Column="2" Text="{Binding UploadFormatted}"
                                                       Style="{StaticResource MonoCellTextStyle}"
                                                       Foreground="{StaticResource OrangeBrush}"/>
                                            <TextBlock Grid.Column="3" Text="{Binding TotalFormatted}"
                                                       Style="{StaticResource MonoCellTextStyle}"/>
                                            <TextBlock Grid.Column="4" Text="{Binding ShareFormatted}"
                                                       Style="{StaticResource MonoCellTextStyle}"
                                                       Foreground="{StaticResource GreenBrush}"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
