<Window x:Class="FlowWatch.Views.UpdateWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource Update.WindowTitle}"
        Width="520" SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Style="{StaticResource SettingsWindowStyle}"
        ShowInTaskbar="True">

    <StackPanel Margin="28">
        <Grid Margin="0,0,0,18">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0">
                <TextBlock x:Name="HeaderText" Style="{StaticResource WindowTitleStyle}"/>
                <TextBlock Text="{DynamicResource Update.Subtitle}" Style="{StaticResource WindowSubtitleStyle}"
                           Margin="0,4,0,0"/>
            </StackPanel>
            <Image Grid.Column="1" Source="/Resources/generated_icon.png" Width="46" Height="46"
                   RenderOptions.BitmapScalingMode="HighQuality" Margin="18,0,0,0"/>
        </Grid>

        <Border Style="{StaticResource ModernCardStyle}" Margin="0,0,0,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="{DynamicResource Update.CurrentVersion}" Style="{StaticResource MetricTitleStyle}"/>
                    <TextBlock x:Name="CurrentVersionText" Style="{StaticResource ValueStyle}" Margin="0,6,0,0"/>
                </StackPanel>
                <StackPanel Grid.Column="1">
                    <TextBlock Text="{DynamicResource Update.LatestVersion}" Style="{StaticResource MetricTitleStyle}"/>
                    <TextBlock x:Name="LatestVersionText" Style="{StaticResource ValueStyle}"
                               Foreground="{StaticResource AccentBrush}" Margin="0,6,0,0"/>
                </StackPanel>
                <StackPanel Grid.Column="2">
                    <TextBlock Text="{DynamicResource Update.PublishedAt}" Style="{StaticResource MetricTitleStyle}"/>
                    <TextBlock x:Name="PublishedAtText" Style="{StaticResource ValueStyle}" Margin="0,6,0,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <TextBlock Text="{DynamicResource Update.ReleaseNotes}" Style="{StaticResource SectionTitleStyle}"
                   Margin="0,0,0,8"/>
        <Border Style="{StaticResource SoftPanelStyle}" Margin="0,0,0,16">
            <ScrollViewer Style="{StaticResource ModernScrollViewerStyle}"
                          VerticalScrollBarVisibility="Auto" MaxHeight="138">
                <TextBlock x:Name="ReleaseNotesText" TextWrapping="Wrap"
                           Foreground="{StaticResource TextBrush}" FontSize="12.5"
                           LineHeight="19"/>
            </ScrollViewer>
        </Border>

        <StackPanel x:Name="ProgressPanel" Visibility="Collapsed" Margin="0,0,0,16">
            <DockPanel Margin="0,0,0,8">
                <TextBlock Text="{DynamicResource Update.Downloading}" Style="{StaticResource FieldLabelStyle}"
                           DockPanel.Dock="Left"/>
                <TextBlock x:Name="ProgressPercentText" Style="{StaticResource ValueStyle}"
                           DockPanel.Dock="Right" HorizontalAlignment="Right"/>
            </DockPanel>
            <ProgressBar x:Name="DownloadProgress" Minimum="0" Maximum="100"
                         Style="{StaticResource ModernProgressBarStyle}"/>
        </StackPanel>

        <Grid x:Name="ButtonPanel">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Button x:Name="SkipButton" Content="{DynamicResource Update.SkipVersion}"
                    Style="{StaticResource SecondaryButtonStyle}"
                    Grid.Column="0" HorizontalAlignment="Left"
                    Click="OnSkipClick" MinWidth="96"/>
            <Button x:Name="LaterButton" Content="{DynamicResource Update.Later}"
                    Style="{StaticResource SecondaryButtonStyle}"
                    Grid.Column="1" HorizontalAlignment="Right"
                    Click="OnLaterClick" MinWidth="86"/>
            <Button x:Name="UpdateButton" Content="{DynamicResource Update.UpdateNow}"
                    Style="{StaticResource PrimaryButtonStyle}"
                    Grid.Column="3" HorizontalAlignment="Right"
                    Click="OnUpdateClick" MinWidth="96"/>
        </Grid>
    </StackPanel>
</Window>
