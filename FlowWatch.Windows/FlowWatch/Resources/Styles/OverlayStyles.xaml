<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Light text outline/shadow to improve readability on bright backgrounds -->
    <DropShadowEffect x:Key="OverlayTextShadow"
                      Color="Black"
                      ShadowDepth="0"
                      BlurRadius="3.0"
                      Opacity="0.58"/>

    <!-- Base overlay text style -->
    <Style x:Key="OverlayTextBase" TargetType="TextBlock">
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="FontWeight" Value="ExtraBold"/>
        <Setter Property="Effect" Value="{StaticResource OverlayTextShadow}"/>
        <Setter Property="TextOptions.TextFormattingMode" Value="Display"/>
        <Setter Property="TextOptions.TextHintingMode" Value="Fixed"/>
    </Style>

    <!-- Num style with tabular figures and right alignment -->
    <Style x:Key="NumStyle" TargetType="TextBlock" BasedOn="{StaticResource OverlayTextBase}">
        <Setter Property="MinWidth" Value="34"/>
        <Setter Property="TextAlignment" Value="Right"/>
        <Setter Property="Typography.NumeralAlignment" Value="Tabular"/>
    </Style>

    <!-- Unit style -->
    <Style x:Key="UnitStyle" TargetType="TextBlock" BasedOn="{StaticResource OverlayTextBase}">
        <Setter Property="MinWidth" Value="14"/>
        <Setter Property="Opacity" Value="1"/>
    </Style>

    <!-- Label style (arrow) -->
    <Style x:Key="LabelStyle" TargetType="TextBlock" BasedOn="{StaticResource OverlayTextBase}">
        <Setter Property="MinWidth" Value="12"/>
        <Setter Property="TextAlignment" Value="Center"/>
        <Setter Property="FontSize" Value="16"/>
    </Style>

    <!-- Secondary (usage) style -->
    <Style x:Key="SecondaryStyle" TargetType="TextBlock" BasedOn="{StaticResource OverlayTextBase}">
        <Setter Property="Opacity" Value="1"/>
    </Style>

</ResourceDictionary>
